    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "minio": "^8.0.7",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
