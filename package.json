{
  "name": "hotel-booking-be",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "start": "npm run build && cp -r src/templates dist/ && node dist/server.js",
    "dev": "dotenv -e .env -- ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:local": "dotenv -e .env ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:server": "dotenv -e .env.dev ts-node-dev --respawn --transpile-only src/server.ts",
    "start:dev": "npm run build && dotenv -e .env.dev node dist/server.js",
    "start:prod": "npm run build && dotenv -e .env.prod node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:dev": "dotenv -e .env.dev -- prisma migrate dev",
    "prisma:migrate:prod": "dotenv -e .env.prod -- prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:studio:local": "dotenv -e .env prisma studio",
    "prisma:studio:dev": "dotenv -e .env.dev prisma studio",
    "prisma:studio:prod": "dotenv -e .env.prod prisma studio",
    "postinstall": "prisma generate"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trithuc2909/Hotel-Booking-BE.git"
  },
  "keywords": [],
