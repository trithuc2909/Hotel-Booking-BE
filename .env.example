# Environment: development | production
NODE_ENV=development

# Server Port
PORT=3001

# DATABASE CONFIGURATION
# Local: postgresql://postgres:password@localhost:5432/hotel_db
# Dev: postgresql://user:pass@dev-server.com:5432/hotel_dev
# Prod: postgresql://user:pass@prod-server.com:5432/hotel_prod
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/hotel_local"

# JWT SECURITY
# Generate strong secret: openssl rand -base64 32
ACCESS_TOKEN_SECRET="your-access-token-secret-change-this"
REFRESH_TOKEN_SECRET="your-refresh-token-secret-change-this"
JWT_EXPIRESIN="1h"

# CORS CONFIGURATION
# Multiple origins: http://localhost:3000,http://localhost:5173
CORS_ORIGIN="http://localhost:3000"

# LOGGING
# Levels: error | warn | info | debug
LOG_LEVEL="debug"

# SECURITY (Optional)
RATE_LIMIT_ENABLE=false
RATE_LIMIT_MAX=100