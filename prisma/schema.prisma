// Prisma schema Hệ thống Quản lý Khách Sạn
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// QUẢN LÝ NGƯỜI DÙNG & PHÂN QUYỀN
model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  username              String    @unique
  password              String    // Hashed password
  fullName              String
  phone                 String?
  role                  UserRole  @default(STAFF)
  status                String?   @default("ACT") @db.VarChar(5)
  createdOn             DateTime? @default(now()) @db.Timestamp(6)
  createdBy             String?   @db.VarChar(100)
  modifiedOn            DateTime? @db.Timestamp(6)
  modifiedBy            String?   @db.VarChar(100)

  bookings  Booking[]
  payments  Payment[]
  @@map("users")
}
enum UserRole {
  ADMIN      
  MANAGER   
  STAFF     
  RECEPTIONIST 
}

// ============================================
// REGION: QUẢN LÝ PHÒNG
// ============================================

model RoomType {
  id                    String    @id @default(cuid())
  name                  String    @unique // VD: "Deluxe", "Suite", "Standard"
  description           String?
  basePrice             Decimal   @db.Decimal(10, 2) // Giá cơ bản
  maxGuests             Int       // Số khách tối đa
  amenities             String[]  // Tiện nghi: ["WiFi", "TV", "Air Conditioner"]
  images                String[]  // URLs của hình ảnh
  status                String?   @default("ACT") @db.VarChar(5)
  createdOn             DateTime? @default(now()) @db.Timestamp(6)
  createdBy             String?   @db.VarChar(100)
  modifiedOn            DateTime? @db.Timestamp(6)
  modifiedBy            String?   @db.VarChar(100)

  rooms Room[]
  @@map("room_types")
}
model Room {
  id                    String     @id @default(cuid())
  roomNumber            String     @unique 
  floor                 Int        
  roomTypeId            String
  notes                 String?
  status                RoomStatus @default(AVAILABLE)    
  createdOn             DateTime?  @default(now()) @db.Timestamp(6)
  createdBy             String?    @db.VarChar(100)
  modifiedOn            DateTime?  @db.Timestamp(6)
  modifiedBy            String?    @db.VarChar(100)

  roomType              RoomType   @relation(fields: [roomTypeId], references: [id])
  bookings              Booking[]
  @@map("rooms")
}
enum RoomStatus {
  AVAILABLE    // Phòng trống
  OCCUPIED     // Đang có khách
  CLEANING     // Đang dọn dẹp
  MAINTENANCE  // Đang bảo trì
  RESERVED     // Đã đặt trước
}

// ============================================
// REGION: QUẢN LÝ KHÁCH HÀNG
// ============================================

model Customer {
  id                    String     @id @default(cuid())
  fullName              String
  email                 String?
  phone                 String     @unique
  idCard                String?    @unique // CMND/CCCD
  address               String?
  nationality           String?    @default("Vietnam")
  dateOfBirth           DateTime?
  notes                 String?
  createdOn             DateTime?  @default(now()) @db.Timestamp(6)
  modifiedOn            DateTime?  @db.Timestamp(6)
  
  bookings              Booking[]
  @@map("customers")
}

// ============================================
// REGION: QUẢN LÝ ĐẶT PHÒNG
// ============================================

model Booking {
  id              String        @id @default(cuid())
  bookingCode     String        @unique // Mã đặt phòng: "BK-20260110001"
  customerId      String
  roomId          String
  checkInDate     DateTime
  checkOutDate    DateTime
  numberOfGuests  Int
  totalAmount     Decimal       @db.Decimal(10, 2)
  depositAmount   Decimal       @default(0) @db.Decimal(10, 2)
  status          BookingStatus @default(PENDING)
  notes           String?
  createdOn       DateTime?     @default(now()) @db.Timestamp(6)
  createdById     String?
  modifiedOn      DateTime?     @db.Timestamp(6)
  modifiedBy      String?       @db.VarChar(100)

  customer        Customer      @relation(fields: [customerId], references: [id])
  room            Room          @relation(fields: [roomId], references: [id])
  createdBy       User?         @relation(fields: [createdById], references: [id])
  payments        Payment[]
  services        BookingService[]
  @@map("bookings")
}
enum BookingStatus {
  PENDING      // Chờ xác nhận
  CONFIRMED    // Đã xác nhận
  CHECKED_IN   // Đã check-in
  CHECKED_OUT  // Đã check-out
  CANCELLED    // Đã hủy
  NO_SHOW      // Không đến
}

// ============================================
// REGION: QUẢN LÝ DỊCH VỤ
// ============================================

model Service {
  id          String     @id @default(cuid())
  name        String     @unique // VD: "Giặt ủi", "Spa", "Ăn sáng"
  description String?
  price       Decimal    @db.Decimal(10, 2)
  unit        String     // Đơn vị: "lần", "người", "món"
  category    String?    // Phân loại: "F&B", "Laundry", "Spa"
  status      String?    @default("ACT") @db.VarChar(5)
  createdOn   DateTime?  @default(now()) @db.Timestamp(6)
  createdBy   String?    @db.VarChar(100)
  modifiedOn  DateTime?  @db.Timestamp(6)
  modifiedBy  String?    @db.VarChar(100)

  bookingServices BookingService[]
  @@map("services")
}
model BookingService {
  id          String   @id @default(cuid())
  bookingId   String
  serviceId   String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(10, 2) // Giá tại thời điểm sử dụng
  totalPrice  Decimal  @db.Decimal(10, 2)
  notes       String?
  status      String?    @default("ACT") @db.VarChar(5)
  createdOn   DateTime?  @default(now()) @db.Timestamp(6)
  createdBy   String?    @db.VarChar(100)
  modifiedOn  DateTime?  @db.Timestamp(6)
  modifiedBy  String?    @db.VarChar(100)

  booking    Booking  @relation(fields: [bookingId], references: [id])
  service    Service  @relation(fields: [serviceId], references: [id])
  @@map("booking_services")
}

// ============================================
// REGION: QUẢN LÝ THANH TOÁN
// ============================================

model Payment {
  id              String        @id @default(cuid())
  bookingId       String
  amount          Decimal       @db.Decimal(10, 2)
  paymentMethod   PaymentMethod
  paymentDate     DateTime      @default(now())
  notes           String?
  status          String?       @default("ACT") @db.VarChar(5)
  createdOn       DateTime?     @default(now()) @db.Timestamp(6)
  createdById     String?
  modifiedOn      DateTime?     @db.Timestamp(6)
  modifiedBy      String?       @db.VarChar(100)

  booking         Booking       @relation(fields: [bookingId], references: [id])
  createdBy       User?          @relation(fields: [createdById], references: [id])
  @@map("payments")
}
enum PaymentMethod {
  CASH          // Tiền mặt
  BANK_TRANSFER // Chuyển khoản
  CREDIT_CARD   // Thẻ tín dụng
  MOMO          // Ví MoMo
  VNPAY         // VNPay
}