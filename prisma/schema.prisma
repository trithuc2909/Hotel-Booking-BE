// Prisma schema Hệ thống Quản lý Khách Sạn
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// QUẢN LÝ NGƯỜI DÙNG & PHÂN QUYỀN
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  password      String    // Hashed password
  phone         String?
  role          UserRole  @default(USER)
  status        String?   @default("INA") @db.VarChar(5)
  createdOn     DateTime? @default(now()) @db.Timestamp(6)
  createdBy     String?   @db.VarChar(100)
  modifiedOn    DateTime? @db.Timestamp(6)
  modifiedBy    String?   @db.VarChar(100)
  
  otps      OTP[]
  bookings  Booking[]
  payments  Payment[]

  @@map("users")
  @@index([email])
  @@index([username])
}
enum UserRole {
  ADMIN
  USER
}

// ============================================
// REGION: QUẢN LÝ OTP
// ============================================

model OTP {
  id          String    @id @default(uuid())
  userId      String
  code        String    // hash otp
  purpose     OTPType
  expiresAt   DateTime  @db.Timestamp(6)
  usedOn      DateTime? @db.Timestamp(6)   
  createdOn   DateTime? @default(now()) @db.Timestamp(6)

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, purpose])
  @@map("otps")
}

enum OTPType {
  REGISTER
  RESET_PASSWORD
}

// ============================================
// REGION: QUẢN LÝ PHÒNG
// ============================================

model RoomType {
  id                    String    @id @default(cuid())
  code                  String    @unique // VD: "Deluxe", "Suite", "Standard"
  name                  String    
  description           String?
  basePrice             Decimal   @db.Decimal(10, 2) 
  maxGuests             Int       
  thumbnailUrl          String
  status                String?   @default("ACT") @db.VarChar(5)
  createdOn             DateTime? @default(now()) @db.Timestamp(6)
  createdBy             String?   @db.VarChar(100)
  modifiedOn            DateTime? @db.Timestamp(6)
  modifiedBy            String?   @db.VarChar(100)

  rooms                 Room[]
  amenities             RoomTypeAmenity[]
  images                RoomTypeImage[]

  @@map("room_types")
}
model Room {
  id                    String     @id @default(cuid())
  roomNumber            String     @unique 
  floor                 Int        
  roomTypeId            String
  notes                 String?
  status                RoomStatus @default(AVAILABLE)    
  createdOn             DateTime?  @default(now()) @db.Timestamp(6)
  createdBy             String?    @db.VarChar(100)
  modifiedOn            DateTime?  @db.Timestamp(6)
  modifiedBy            String?    @db.VarChar(100)

  roomType              RoomType   @relation(fields: [roomTypeId], references: [id])
  bookings              Booking[]
  @@map("rooms")
}
model RoomTypeImage {
  id             String     @id @default(cuid())
  roomTypeId     String
  imageUrls      String
  displayOrder   Int        @default(0)  //Thứ tự hiển thị
  createdOn      DateTime?  @default(now()) @db.Timestamp(6)

  roomType RoomType @relation(fields: [roomTypeId], references: [id])

  @@map("room_type_images")
}
enum RoomStatus {
  AVAILABLE    // Phòng trống
  OCCUPIED     // Đang có khách
  CLEANING     // Đang dọn dẹp
  MAINTENANCE  // Đang bảo trì
  RESERVED     // Đã đặt trước
}
model Amenity {
  id        String @id @default(cuid())
  name      String @unique
  status    String @default("ACT") @db.VarChar(5)

  roomTypes RoomTypeAmenity[]

  @@map("amenities")
}
model RoomTypeAmenity {
  roomTypeId  String
  amenityId   String

  roomType    RoomType @relation(fields: [roomTypeId], references: [id])
  amenity     Amenity  @relation(fields: [amenityId], references: [id])

  @@id([roomTypeId, amenityId])
  @@map("room_type_amenities")
}

// ============================================
// REGION: QUẢN LÝ KHÁCH HÀNG
// ============================================

enum CustomerType {
  INDIVIDUAL    // Khách lẻ
  VIP           // Khách VIP
  CORPORATE     // Doanh nghiệp
  REGULAR       // Khách quen
}
model Customer {
  id                String        @id @default(cuid())
  customerType      CustomerType  @default(INDIVIDUAL)
  fullName          String
  email             String?
  phone             String        @unique
  idCard            String?       @unique // CMND/CCCD
  address           String?
  nationality       String?       @default("Vietnam")
  dateOfBirth       DateTime?
  notes             String?
  createdOn         DateTime?     @default(now()) @db.Timestamp(6)
  modifiedOn        DateTime?     @db.Timestamp(6)
  
  bookings          Booking[]
  @@map("customers")
}

// ============================================
// REGION: QUẢN LÝ ĐẶT PHÒNG
// ============================================

model Booking {
  id                   String        @id @default(cuid())
  bookingCode          String        @unique // Mã đặt phòng: "BK-20260110001"
  customerId           String
  roomId               String
  checkInDate          DateTime
  checkOutDate         DateTime
  actualCheckInDate    DateTime?  
  actualCheckOutDate   DateTime?
  numberOfGuests       Int
  roomPrice            Decimal       @db.Decimal(10,2)
  totalService         Decimal       @default(0) @db.Decimal(10,2)
  discount             Decimal       @default(0) @db.Decimal(10,2)
  totalAmount          Decimal       @db.Decimal(10, 2)
  depositAmount        Decimal       @default(0) @db.Decimal(10, 2)
  paidAmount           Decimal       @default(0) @db.Decimal(10, 2)
  status               BookingStatus @default(PENDING)
  notes                String?
  createdOn            DateTime?     @default(now()) @db.Timestamp(6)
  createdById          String?
  modifiedOn           DateTime?     @db.Timestamp(6)
  modifiedBy           String?       @db.VarChar(100)

  customer             Customer      @relation(fields: [customerId], references: [id])
  room                 Room          @relation(fields: [roomId], references: [id])
  createdBy            User?         @relation(fields: [createdById], references: [id])
  payments             Payment[]
  services             BookingService[]

  @@map("bookings")
}
enum BookingStatus {
  PENDING      // Chờ xác nhận
  CONFIRMED    // Đã xác nhận
  CHECKED_IN   // Đã check-in
  CHECKED_OUT  // Đã check-out
  CANCELLED    // Đã hủy
  NO_SHOW      // Không đến
}

// ============================================
// REGION: QUẢN LÝ DỊCH VỤ
// ============================================
model ServiceCategory {
  id        String  @id @default(cuid())
  name      String  @unique
  status    String  @default("ACT") @db.VarChar(5)

  services  Service[]

  @@map("service_categories")
}

model Service {
  id                  String     @id @default(cuid())
  serviceCategoryId   String
  name                String     @unique // VD: "Giặt ủi", "Spa", "Ăn sáng"
  description         String?
  basePrice           Decimal    @db.Decimal(10, 2)
  unit                String     // Đơn vị: "lần", "người", "món"
  status              String?    @default("ACT") @db.VarChar(5)
  createdOn           DateTime?  @default(now()) @db.Timestamp(6)
  createdBy           String?    @db.VarChar(100)
  modifiedOn          DateTime?  @db.Timestamp(6)
  modifiedBy          String?    @db.VarChar(100)

  category            ServiceCategory   @relation(fields: [serviceCategoryId], references: [id])
  bookingServices     BookingService[]

  @@map("services")
}
model BookingService {
  id          String   @id @default(cuid())
  bookingId   String
  serviceId   String
  serviceName String
  quantity    Int      @default(1)
  unit        String
  unitPrice   Decimal  @db.Decimal(10, 2) // Giá tại thời điểm sử dụng
  totalPrice  Decimal  @db.Decimal(10, 2)
  status      String?    @default("ACT") @db.VarChar(5)
  createdOn   DateTime?  @default(now()) @db.Timestamp(6)
  createdBy   String?    @db.VarChar(100)
  modifiedOn  DateTime?  @db.Timestamp(6)
  modifiedBy  String?    @db.VarChar(100)

  booking    Booking  @relation(fields: [bookingId], references: [id])
  service    Service  @relation(fields: [serviceId], references: [id])
  @@map("booking_services")
}

// ============================================
// REGION: QUẢN LÝ THANH TOÁN
// ============================================

model Payment {
  id              String        @id @default(cuid())
  bookingId       String
  transactionId   String?
  amount          Decimal       @db.Decimal(10, 2)
  paymentMethod   PaymentMethod
  paymentDate     DateTime      @default(now())
  notes           String?
  status          String?       @default("ACT") @db.VarChar(5)
  createdOn       DateTime?     @default(now()) @db.Timestamp(6)
  createdById     String?
  modifiedOn      DateTime?     @db.Timestamp(6)
  modifiedBy      String?       @db.VarChar(100)

  booking         Booking       @relation(fields: [bookingId], references: [id])
  createdBy       User?          @relation(fields: [createdById], references: [id])
  @@map("payments")
}
enum PaymentMethod {
  CASH          // Tiền mặt
  BANK_TRANSFER // Chuyển khoản
  CREDIT_CARD   // Thẻ tín dụng
  MOMO          // Ví MoMo
  VNPAY         // VNPay
}


// ============================================
// REGION: QUẢN LÝ CODES
// ============================================

model Code {
  id          String     @id @default(cuid())
  type        String     @db.VarChar(50) // BOOKING_STATUS, ROOM_STATUS
  code        String     @db.VarChar(50)
  displayAs   String     @db.VarChar(100)
  isActive    Boolean    @default(true)
  createdOn   DateTime?  @default(now()) @db.Timestamp(6)
  createdBy   String?    @db.VarChar(100)
  modifiedOn  DateTime?  @db.Timestamp(6)
  modifiedBy  String?    @db.VarChar(100)

  @@unique([type, code])
  @@index([type])
  @@map("codes")
}